# PostgreSQL + TimescaleDB
POSTGRES_DB=degen
POSTGRES_USER=degen
POSTGRES_PASSWORD=changeme

# RabbitMQ
RABBITMQ_DEFAULT_USER=degen
RABBITMQ_DEFAULT_PASS=changeme
RABBITMQ_URL=amqp://degen:changeme@localhost:5672

# Redis (cache only, optional Phase 1)
REDIS_URL=redis://localhost:6379

# Kraken
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_WS_URL=wss://ws.kraken.com/v2

# AI (Phase 5+)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Internal service URLs (Docker network)
SERVICES__MARKETDATA=http://worker-market:8080
SERVICES__EXECUTION=http://svc-execution:8080
SERVICES__ANALYTICS=http://svc-analytics:8080
